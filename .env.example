# Roomix Platform Console — environment template.
# Copy to `.env.local` and adjust per machine. Never commit a real `.env`.
#
# VITE_ROOMIX_API_BASE
#   Where the Roomix SaaS backend lives. The Console's Vite dev server
#   proxies /api/* to this origin so cookies stay first-party on
#   http://localhost:5174. Production deploys should set this in the
#   hosting environment (Railway, etc.) — NOT in the bundle.
#   Default (local-dev): http://localhost:3000
VITE_ROOMIX_API_BASE=http://localhost:3000
